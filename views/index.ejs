<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>CRUD - Temas y Enlaces</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="contenedor">

    <div class="card">
      <form id="formulario-tema" class="formulario">
        <div class="campo">
          <label>Tema</label>
          <input type="text" id="entrada-tema" required placeholder="Nombre del tema">
        </div>
        <div class="campo">
          <label>Primer Enlace (opcional)</label>
          <input type="text" id="entrada-enlace" placeholder="https://ejemplo.com">
        </div>
        <button type="submit" class="btn btn-azul">Añadir Tema</button>
      </form>
    </div>

    <div class="tabla-contenedor">
      <% if (records.length === 0) { %>
        <p style="text-align: center; color: #999; margin-top: 20px;">No hay temas registrados.</p>
      <% } else { %>
        <% records.forEach(function(registro) { %>
          
          <div class="tema-contenedor card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
              <h2 style="font-size: 1.25rem;"><%= registro.tema %></h2>
              <div class="acciones-tema">
                <button class="btn-editar-tema btn btn-azul" data-id="<%= registro.id %>">Editar</button>
                <button class="btn-eliminar-tema btn btn-rojo" data-id="<%= registro.id %>">Eliminar</button>
              </div>
            </div>

            <div style="display: flex; gap: 10px; margin-bottom: 20px;">
              <input type="text" 
                     class="entrada-nuevo-enlace" 
                     data-tema-id="<%= registro.id %>" 
                     placeholder="Ingresa la URL del nuevo enlace..."
                     style="flex: 1; padding: 0.6rem; border: 1px solid #e2e8f0; border-radius: 8px;">
              <button type="button" 
                      class="btn-agregar-enlace btn btn-verde" 
                      data-tema-id="<%= registro.id %>">Agregar</button>
            </div>

            <% if (registro.enlaces && registro.enlaces.length > 0) { %>
              <table>
                <thead>
                  <tr>
                    <th>Votos</th>
                    <th>Enlace</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% registro.enlaces.forEach(function(enlace) { %>
                    <tr class="enlace-item">
                      <td><span class="votos-enlace badge-votos"><%= enlace.votos %></span></td>
                      <td>
                        <a href="<%= enlace.url %>" target="_blank" class="enlace-url">
                          <%= enlace.url %>
                        </a>
                      </td>
                      <td>
                        <div class="acciones">
                          <button class="btn-votar-enlace btn btn-verde" data-enlace-id="<%= enlace.id %>">+1</button>
                          <button class="btn-editar-enlace btn btn-azul" data-enlace-id="<%= enlace.id %>">Editar</button>
                          <button class="btn-eliminar-enlace btn btn-rojo" data-enlace-id="<%= enlace.id %>">Eliminar</button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <div style="text-align: center; color: #64748b; padding: 15px; border: 1px dashed #e2e8f0; border-radius: 8px;">
                Sin enlaces agregados.
              </div>
            <% } %>
          </div>

        <% }) %>
      <% } %>
    </div>
  </div>

  <script src="/js/form.js"></script>
</body>
</html>